# ─────────────────────────────────────────────────────────────
#  Emkay Surveys Nigeria Limited — Environment Configuration
#  Copy this file to .env and fill in your real values.
# ─────────────────────────────────────────────────────────────

# Database (SQLite default — swap for PostgreSQL in production)
DATABASE_URL=sqlite:///./emkay.db
# DATABASE_URL=postgresql://user:password@localhost/emkay_db

# Admin Dashboard Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=emkay2025!

# CORS — your frontend URL(s), comma-separated
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:5500","*"]

# Email / SMTP
# Set to true to enable email notifications
SMTP_ENABLED=false

# Gmail SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=Emkay Surveys <your-gmail@gmail.com>

# Where to send new enquiry notifications
NOTIFY_EMAIL=Emkaysurveys@gmail.com
